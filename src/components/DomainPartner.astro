<section class="section-padding">
  <div class="container">
    <div class="domain-partner-wrapper">
      <h2 class="section-title reveal-on-scroll">Partner Dengan <span class="text-gradient">Domain Register</span></h2>
      <p class="section-subtitle reveal-on-scroll" style="transition-delay: 100ms">
        Kami telah bekerja sama dengan berbagai registrar domain tepercaya untuk memastikan Anda mendapatkan ekstensi domain terbaik untuk bisnis atau proyek Anda. Daftarkan dan kelola ekstensi populer seperti .com, .id, .net, dan banyak lagi langsung dari satu tempat.
      </p>

      <div class="domain-image-container reveal-on-scroll" style="transition-delay: 200ms;">
        <img src="/images/domain_logos.webp" width="851" height="315" alt="Ekstensi Domain Populer" class="domain-logos animate-float" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

<style>
  .domain-partner-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .domain-image-container {
    margin-top: 2rem;
    padding: 3rem 2rem;
    background: var(--surface-color);
    backdrop-filter: var(--glass-backdrop);
    -webkit-backdrop-filter: var(--glass-backdrop);
    border: var(--glass-border);
    border-radius: 2rem;
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 800px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .domain-logos {
    max-width: 100%;
    height: auto;
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.1));
  }
</style>
