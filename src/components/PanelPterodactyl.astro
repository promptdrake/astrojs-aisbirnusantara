---
import { Image } from 'astro:assets';
import panelpteropng from '../assets/panel_ptero.png';
---

<section class="section-padding section-grid-bg">
  <div class="container">
    <div class="panel-layout">
      <div class="panel-image reveal-on-scroll" style="transition-delay: 100ms;">
        <Image src={panelpteropng}  alt="Mockup Pterodactyl Panel" class="mockup-img animate-float" style="animation-delay: -2s;" />
      </div>

      <div class="panel-content reveal-on-scroll" style="transition-delay: 200ms;">
        <h2 class="section-title text-left">Panel <span class="text-gradient">Pterodactyl</span></h2>
        <p class="panel-description">
          Kelola server aplikasi Anda dengan sangat mudah menggunakan antarmuka modern Pterodactyl Panel. Dibangun untuk memberikan Anda kontrol penuh, performa tinggi, dan akses instan langsung dari browser perangkat apa pun, termasuk dari genggaman smartphone Anda.
        </p>
        <ul class="panel-features">
          <li>
            <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Akses Konsol Real-time yang Responsif</span>
          </li>
          <li>
            <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Manajemen File Berbasis Browser Terintegrasi</span>
          </li>
          <li>
            <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Tugas Terjadwal (Cron) dan Auto-Restart</span>
          </li>
          <li>
            <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Isolasi Kontainer Docker untuk Keamanan Ekstra</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .section-grid-bg {
    background-size: 40px 40px;
    background-image: 
      linear-gradient(to right, rgba(139, 92, 246, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(139, 92, 246, 0.08) 1px, transparent 1px);
    background-position: center top;
  }
  
  :global(html.dark) .section-grid-bg {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  }

  .panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .text-left {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .panel-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .panel-features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
  }

  .panel-features li {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.05rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .check-icon {
    color: var(--secondary-accent);
    flex-shrink: 0;
    background: rgba(139, 92, 246, 0.1);
    border-radius: 50%;
    padding: 0.1rem;
    width: 24px;
    height: 24px;
  }

  .panel-image {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mockup-img {
    width: 100%;
    max-width: 600px;
    height: auto;
    filter: drop-shadow(0 25px 35px rgba(0, 0, 0, 0.15));
  }

  @media (max-width: 992px) {
    .panel-layout {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    
    .panel-image {
      order: -1;
    }

    .text-left {
      text-align: center;
    }

    .panel-features li {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
