            <img src="" alt="" class="tech-logo" />
          </div>
          <div class="tech-logo-slot" data-slot="2">
            <img src="https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Laravel/png/LaravelTransparent.png?raw=true" alt="Laravel" class="tech-logo active" />
