<style>
.hero-section{
  position:relative;
  padding:10rem 0 6rem;
  min-height:90vh;
  display:flex;
  align-items:center;
  overflow:hidden;
  background-image:url('https://id-cdn.aisbirnusantara.com/portal/b52046737d3ff17bf048a4f62fa09092.jpg');
  background-size:cover;
  background-position:center;
}

.hero-section::before{
  content:'';
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.42);
  z-index:1;
}

/* glow */

.cursor-glow{
  position:absolute;
  width:550px;
  height:550px;
  background:radial-gradient(circle,
      rgba(56,189,248,.18) 0%,
      rgba(96,165,250,.05) 60%,
      transparent 80%);
  border-radius:50%;
  pointer-events:none;
  transform:translate(-50%,-50%);
  z-index:2;
  opacity:0;
  transition:opacity .3s ease;
  filter:blur(55px);
}

/* sakura */

.sakura-container{
  position:absolute;
  inset:0;
  overflow:hidden;
  z-index:2;
  pointer-events:none;
}


/* content */

.hero-container{
  position:relative;
  z-index:10;
  text-align:center;
  color:white;
}

.hero-content{
  max-width:800px;
  margin:0 auto;
}

.badge-wrapper{
  margin-bottom:2rem;
}

.hero-title{
  font-size:4rem;
  font-weight:800;
  line-height:1.1;
  margin-bottom:1.5rem;
  letter-spacing:-.02em;
  color:white;
  text-shadow:0 4px 12px rgba(0,0,0,.5);
}

.hero-title .text-gradient{
  background:linear-gradient(
    135deg,
    #41d8ff 0%,
    #19c5ff 45%,
    #00eaff 100%
  );
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  text-shadow:0 2px 12px rgba(255,255,255,.12);
}

.hero-subtitle{
  font-size:1.25rem;
  color:white;
  margin-bottom:3rem;
  line-height:1.6;
  text-shadow:0 2px 8px rgba(0,0,0,.6);
}

.hero-actions{
  display:flex;
  justify-content:center;
  gap:1rem;
  margin-bottom:4rem;
}

.btn-lg{
  padding:1rem 2rem;
  font-size:1.125rem;
}

.hero-btn-outline{
  background:rgba(255,255,255,.08)!important;
  backdrop-filter:blur(8px);
  color:white!important;
  border:1px solid rgba(255,255,255,.18)!important;
}

.tech-card-wrapper {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.tech-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 24px;
  padding: 1.5rem 2rem;
  width: 100%;
  max-width: 650px;
  min-height: 120px;
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.25);
  transition: transform 0.2s ease, border-color 0.2s ease;
  box-sizing: border-box;
  gap: 1.5rem;
}

.tech-card:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.25);
}

.tech-logo-slot {
  position: relative;
  width: 120px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.tech-logo {
  position: absolute;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  opacity: 0;
  transform: scale(0.9);
  transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
  pointer-events: none;
