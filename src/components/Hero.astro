</style>

<script>
/* glow */

const hero=document.querySelector('.hero-section');
const glow=document.getElementById('hero-glow');

if(hero && glow){
  if(window.matchMedia('(pointer:fine)').matches){

    hero.addEventListener('mousemove',(e)=>{
      const rect=hero.getBoundingClientRect();
      glow.style.left=(e.clientX-rect.left)+'px';
      glow.style.top=(e.clientY-rect.top)+'px';
    });

    hero.addEventListener('mouseenter',()=>{
      glow.style.opacity='1';
    });

    hero.addEventListener('mouseleave',()=>{
      glow.style.opacity='0';
    });
  }
}

/* LIGHT sakura rain */

function initSakura() {
  const sakuraContainer = document.getElementById('sakura-container');
  if (sakuraContainer) {
    const petals = 14;
    for (let i = 0; i < petals; i++) {
      createPetal(sakuraContainer);
    }
  }
}

function initTechLogos() {
  const LOGO_POOL = [
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Node.js/png/Node.js.png?raw=true", alt: "Node.js" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Go%20Lang/png/Golang.png?raw=true", alt: "Go Lang" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Laravel/png/LaravelTransparent.png?raw=true", alt: "Laravel" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/TypeScript/png/TypeScript.png?raw=true", alt: "TypeScript" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Next.js/png/Next.js.png?raw=true", alt: "Next.js" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/GitHub/png/GitHub.png?raw=true", alt: "GitHub" },
    { src: "https://github.com/SAWARATSUKI/KawaiiLogos/blob/main/Express/png/Express.png?raw=true", alt: "Express" }
  ];

  let activeLogos = [0, 1, 2]; // Match starting HTML values

  const slots = document.querySelectorAll('.tech-logo-slot');
  slots.forEach((slot, slotIdx) => {
    setTimeout(() => {
      setInterval(() => {
        // Find pool indices not currently displayed in any slot
        const unusedIndices = [];
        for (let i = 0; i < LOGO_POOL.length; i++) {
          if (!activeLogos.includes(i)) {
            unusedIndices.push(i);
          }
        }
        
        if (unusedIndices.length === 0) return;
        
        // Pick one at random
        const nextIdx = unusedIndices[Math.floor(Math.random() * unusedIndices.length)];
        
        // Mark it as active for this slot
        activeLogos[slotIdx] = nextIdx;
        
        // Double-buffered swap
        const imgs = slot.querySelectorAll('.tech-logo');
        const activeImg = slot.querySelector('.tech-logo.active');
        const nextImg = Array.from(imgs).find(img => img !== activeImg);
        
        if (nextImg && activeImg) {
          nextImg.src = LOGO_POOL[nextIdx].src;
          nextImg.alt = LOGO_POOL[nextIdx].alt;
          
          // Force layout flow so change triggers transition correctly
          nextImg.getBoundingClientRect();
          
          nextImg.classList.add('active');
          activeImg.classList.remove('active');
        }
      }, 4500);
    }, slotIdx * 1500);
  });
}

function initAll() {
  initSakura();
  initTechLogos();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initAll);
} else {
  initAll();
}

function createPetal(container) {
  if (!container) return;
  const petal = document.createElement('div');
  petal.className = 'petal';

  const size = Math.random() * 10 + 8;
  const x = Math.random() * window.innerWidth;
  const duration = Math.random() * 10 + 14;
  const delay = Math.random() * 12;

  petal.style.left = x + 'px';
  petal.style.width = size + 'px';
  petal.style.height = (size * .75) + 'px';
  petal.style.animationDuration = duration + 's';
  petal.style.animationDelay = delay + 's';

  // Make opacity much higher (between 0.4 and 0.8) so they are visible
  petal.style.opacity = (Math.random() * 0.4 + 0.4).toFixed(2);

  // Solid sakura pink colors
  const colors = [
    '#ffd1dc', // light pink
    '#ffb7c5', // sakura pink
    '#ff9ebb', // dark sakura pink
    '#ffe3e8'  // soft rose
  ];

  petal.style.background = colors[Math.floor(Math.random() * colors.length)];

  container.appendChild(petal);

  petal.addEventListener('animationend', () => {
    petal.remove();
    createPetal(container);
  });
}
</script>

<style is:global>
  .petal {
    position: absolute;
    top: -30px;
    border-radius: 12px 2px 12px 2px;
    filter: blur(0.4px);
    will-change: transform;
    animation: sakura-fall linear infinite;
    z-index: 3;
    pointer-events: none;
  }

  @keyframes sakura-fall {
    0% {
      transform: translate3d(0, -20px, 0) rotate(0deg);
    }
    50% {
      transform: translate3d(80px, 50vh, 0) rotate(180deg);
    }
    100% {
      transform: translate3d(160px, 105vh, 0) rotate(360deg);
    }
  }
</style>