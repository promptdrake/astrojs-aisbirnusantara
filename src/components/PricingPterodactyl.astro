---
const plans = [
  {
    name: "Archer",
    price: "Rp 20.000",
    period: "bulan",
    altPrice: "Rp 120.000 / 6 bulan",
    features: [
      "100% Kekuatan CPU",
      "1024 MB RAM",
      "5000 MB Penyimpanan SSD",
      "1 Database",
      "5 Alokasi Port",
      "1 Terowongan (Tunnel) Diizinkan",
      "500 MB/s Kecepatan IO"
    ],
    popular: false
  },
  {
    name: "Knight",
    price: "Rp 25.000",
    period: "bulan",
    altPrice: "Rp 150.000 / 6 bulan",
    features: [
      "100% Kekuatan CPU",
      "2024 MB RAM",
      "10000 MB Penyimpanan SSD",
      "1 Database",
      "10 Alokasi Port",
      "1 Terowongan (Tunnel) Diizinkan",
      "500 MB/s Kecepatan IO"
    ],
    popular: true
  },
  {
    name: "Queen",
    price: "Rp 35.000",
    period: "bulan",
    altPrice: "Rp 210.000 / 6 bulan",
    features: [
      "100% Kekuatan CPU",
      "4024 MB RAM",
      "20000 MB Penyimpanan SSD",
      "5 Database",
      "25 Alokasi Port",
      "1 Terowongan (Tunnel) Diizinkan",
      "500 MB/s Kecepatan IO"
    ],
    popular: false
  },
  {
    name: "King",
    price: "Rp 45.000",
    period: "bulan",
    altPrice: "Rp 270.000 / 6 bulan",
    features: [
      "100% Kekuatan CPU",
      "6024 MB RAM",
      "30000 MB Penyimpanan SSD",
      "5 Database",
      "40 Alokasi Port",
      "1 Terowongan (Tunnel) Diizinkan",
      "500 MB/s Kecepatan IO"
    ],
    popular: false
  },
  {
    name: "More Tunnel",
    price: "Rp 50.000",
    period: "bulan",
    altPrice: "Rp 300.000 / 6 bulan",
    features: [
      "200% Kekuatan CPU",
      "6024 MB RAM",
      "30000 MB Penyimpanan SSD",
      "10 Database",
      "3 Alokasi Port",
      "3 Terowongan (Tunnel) Diizinkan",
      "500 MB/s Kecepatan IO"
    ],
    popular: false
  }
];
---

<section id="pterodactyl" class="section-padding">
  <div class="container">
    <h2 class="section-title reveal-on-scroll">Server <span class="text-gradient">Pterodactyl</span></h2>
    <p class="section-subtitle reveal-on-scroll" style="transition-delay: 100ms">Hosting berkinerja tinggi untuk aplikasi Node.js, Python, Nodemon, dan Golang.</p>
    
    <div class="pricing-grid">
      {plans.map((plan, index) => (
        <div class={`pricing-card glass-panel reveal-on-scroll ${plan.popular ? 'popular' : ''}`} style={`transition-delay: ${(index + 2) * 100}ms`}>
          {plan.popular && (
            <div class="popular-badge">
              <span class="badge badge-popular">Paling Populer</span>
            </div>
          )}
          <div class="card-header">
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-price">
              <span class="price">{plan.price}</span>
              <span class="period">/{plan.period}</span>
            </div>
            <div class="alt-price">atau {plan.altPrice}</div>
          </div>
          
          <ul class="features-list">
            {plan.features.map((feature) => (
              <li>
                <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          
          <div class="card-footer">
            <a href="https://portal.aisbirnusantara.com" target="_blank" rel="noopener noreferrer" class={`btn-full ${plan.popular ? 'btn-primary' : 'btn-outline'}`}>
              Tambah ke Keranjang
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    padding-top: 2rem;
  }

  .pricing-card {
    flex: 1 1 300px;
    max-width: 350px;
    position: relative;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .pricing-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-glow);
  }

  .pricing-card.popular {
    border: 2px solid var(--primary-accent);
    transform: scale(1.05);
  }

  .pricing-card.popular:hover {
    transform: scale(1.05) translateY(-10px);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .card-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: var(--glass-border);
  }

  .plan-name {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .period {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .alt-price {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .features-list {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  .check-icon {
    color: var(--primary-accent);
    flex-shrink: 0;
  }

  .card-footer {
    margin-top: auto;
  }

  .btn-full {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .pricing-card.popular {
      transform: none;
    }
    .pricing-card.popular:hover {
      transform: translateY(-10px);
    }
  }
</style>
