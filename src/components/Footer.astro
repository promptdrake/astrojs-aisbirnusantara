---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid grid grid-4">
      <div class="footer-col col-span-2">
        <a href="/" class="logo">
          <img src="https://id-cdn.aisbirnusantara.com/brand/auth-logo.png" alt="Aisbir Cloud Logo" class="logo-img" />
        </a>
        <p class="footer-desc">
          Memberdayakan perjalanan digital Anda dengan solusi hosting berkinerja tinggi, aman, dan andal. Kesuksesan Anda adalah prioritas kami.
        </p>
      </div>
      
      <div class="footer-col">
        <h4 class="footer-title">Layanan</h4>
        <ul class="footer-links">
          <li><a href="/#pterodactyl">Server Pterodactyl</a></li>
          <li><a href="/#directadmin">Hosting DirectAdmin</a></li>
          <li><a href="https://portal.aisbirnusantara.com">Portal Klien</a></li>
                  <li><a href="https://status.aisbirnusantara.com">Web Status</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4 class="footer-title">Kontak</h4>
        <ul class="footer-links">
          <li><a href="mailto:support@aisbirnusantara.com">Email</a></li>
          <li><a href="https://t.me/aisbirnusantara">Telegram</a></li>
           <li><a href="https://wa.me/6285173118646">Whatsapp</a></li>
            <li><a href="https://discord.gg/FkEfeDFh7c">Discord</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <p>&copy; {currentYear} Aisbir Cloud Nusantara. Hak cipta dilindungi undang-undang.</p>
      <div class="footer-legal-links" style="display: flex; gap: 1.5rem;">
        <a href="/terms" style="color: var(--text-secondary); font-size: 0.95rem; text-decoration: none; transition: color 0.3s ease;">Syarat & Ketentuan</a>
        <a href="/privacy" style="color: var(--text-secondary); font-size: 0.95rem; text-decoration: none; transition: color 0.3s ease;">Kebijakan Privasi</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-solid);
    border-top: var(--glass-border);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }

  .footer-grid {
    margin-bottom: 3rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .logo-img {
    height: 40px;
    width: auto;
    max-width: 250px;
  }

  .footer-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 400px;
  }

  .footer-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    transition: color var(--transition-normal);
  }

  .footer-links a:hover {
    color: var(--primary-accent);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .col-span-2 {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
