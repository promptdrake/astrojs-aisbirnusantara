---
---

<section class="section-padding section-grid-bg">
  <div class="container">
    <div class="ai-layout">
      <div class="ai-content reveal-on-scroll">
        <div class="badge-wrapper" style="margin-bottom: 1rem;">
          <span class="badge badge-popular" style="background: linear-gradient(135deg, #a78bfa 0%, #60a5fa 100%);">Teknologi Baru</span>
        </div>
        <h2 class="section-title text-left">Powered by <span class="text-gradient" style="background: linear-gradient(135deg, #a78bfa 0%, #3b82f6 100%); -webkit-background-clip: text;">AI</span></h2>
        <p class="ai-description">
          Kami telah mengaplikasikan AI yang canggih ke dalam website portal kami supaya lebih <strong>powerful</strong> dalam mempercepat pencarian nama domain dan menyajikan <em>customer service</em> yang responsif, akurat, dan interaktif 24/7.
        </p>
      </div>
      
      <div class="ai-image reveal-on-scroll" style="transition-delay: 200ms;">
        <img src="https://id-cdn.aisbirnusantara.com/brand/ai.png" alt="AI Powered Assistant" class="mockup-img animate-float" />
      </div>
    </div>
  </div>
</section>

<style>
  .section-grid-bg {
    background-size: 40px 40px;
    background-image: 
      linear-gradient(to right, rgba(59, 130, 246, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(59, 130, 246, 0.08) 1px, transparent 1px);
    background-position: center top;
  }
  
  :global(html.dark) .section-grid-bg {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  }

  .ai-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .ai-content, .ai-image {
    position: relative;
    z-index: 1;
  }

  .text-left {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .ai-description {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .ai-image {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mockup-img {
    width: 100%;
    max-width: 320px;
    height: auto;
    filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.15));
  }

  @media (max-width: 992px) {
    .ai-layout {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .text-left {
      text-align: center;
    }
    
    .badge-wrapper {
      display: flex;
      justify-content: center;
    }

    .ai-image {
      order: -1;
    }
  }
</style>
